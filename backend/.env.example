# =============================================
# LocalPulse — Environment Variables
# =============================================
# Copy this file to .env and fill in your keys
# =============================================

# Server
PORT=3000
NODE_ENV=development

# Supabase (free at supabase.com) — Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
# Service role key — Settings -> API -> "service_role" (NOT the anon key).
# Backend-only, never send this to the browser. Required for admin.createUser,
# admin.inviteUserByEmail, admin.deleteUser, and to bypass RLS on data tables.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# Admin bootstrap (used by db/seed.js to create your admin account in Supabase Auth)
ADMIN_EMAIL=yadnesh.deshpande2.1@gmail.com
ADMIN_PASSWORD=change_this_password
# Optional: phone number (E.164, e.g. +14805551234) to receive Twilio SMS alerts
ADMIN_PHONE=

# OpenAI (platform.openai.com) — powers the AI advisor chatbot
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Google Places API (console.cloud.google.com — free tier: 5k calls/month)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Yelp Fusion API (free at yelp.com/developers)
YELP_API_KEY=your_yelp_fusion_api_key

# Twilio — SMS alert to admin when a new access request comes in (twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1your-twilio-number

# App-level API key — a lightweight anti-spam gate on the PUBLIC
# /api/auth/request-access endpoint only (not real auth; it ships to the
# browser so anyone can read it from devtools — it just filters out bots
# hitting the endpoint blind). Make it anything.
APP_API_KEY=change_this_to_anything

# SMTP — email notifications (Gmail: use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yadnesh.deshpande2.1@gmail.com
SMTP_PASS=your_gmail_app_password

# n8n webhook base URL — fires events here for you to automate on (optional)
N8N_WEBHOOK_URL=http://localhost:5678

# Frontend URL — used as the redirect target after a Supabase invite email
# (the "set your password" page). Update after you deploy.
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://localpulse.vercel.app,http://localhost:3000
