# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/localpulse
PGSSL=false

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me

# --- AI advisor ---
# AI_PROVIDER = openai or groq
AI_PROVIDER=openai
AI_MODEL=
# fill in the key for whichever provider you picked above
OPENAI_API_KEY=
GROQ_API_KEY=

# --- Live business data ---
YELP_API_KEY=
GOOGLE_PLACES_API_KEY=

# --- Server ---
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000
